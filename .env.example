# Copy to .env and fill in. Never commit .env.
# Kaggle API - accept the ieee-fraud-detection competition rules once on the website first.
KAGGLE_USERNAME=your_username
KAGGLE_KEY=your_key

# App config (FRAUD_ prefix).
FRAUD_LOG_LEVEL=INFO
FRAUD_MLFLOW_TRACKING_URI=
FRAUD_KAFKA_BOOTSTRAP=localhost:9092
FRAUD_REDIS_URL=redis://localhost:6379/0
